Set Theme { "name": "Grimoire", "background": "#1A120B", "foreground": "#D4C4A8", "black": "#1A120B", "red": "#A0522D", "green": "#6B8E23", "yellow": "#C9A84C", "blue": "#4A5568", "purple": "#7B4B8A", "cyan": "#5F8A8B", "white": "#D4C4A8", "brightBlack": "#2D1F14", "brightRed": "#C0724D", "brightGreen": "#8BAE43", "brightYellow": "#D9B85C", "brightBlue": "#6A7588", "brightPurple": "#9B6BAA", "brightCyan": "#7FAAAB", "brightWhite": "#E4D4B8", "cursor": "#C9A84C", "selectionBackground": "#3D2B1F" }
