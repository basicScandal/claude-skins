Output docs/noir.gif

Set Theme { "name": "Noir", "background": "#0D0D0D", "foreground": "#F5E6C8", "black": "#0D0D0D", "red": "#8B3A3A", "green": "#7A9E7E", "yellow": "#D4A857", "blue": "#4A6B8A", "purple": "#7A4F6D", "cyan": "#8AA6A3", "white": "#F5E6C8", "brightBlack": "#1A1A1A", "brightRed": "#AA5555", "brightGreen": "#9ABE9E", "brightYellow": "#E4B867", "brightBlue": "#6A8BAA", "brightPurple": "#9A6F8D", "brightCyan": "#AAC6C3", "brightWhite": "#FFF6D8", "cursor": "#D4A857", "selectionBackground": "#4A6B8A" }
Set FontFamily "JetBrains Mono"
Set FontSize 16
Set Width 900
Set Height 550
Set WindowBar Colorful
Set BorderRadius 8
Set Padding 20
Set TypingSpeed 35ms
Set Framerate 24

Hide
Type `export PS1="$(printf '\033[38;2;212;168;87m◆ \033[38;2;245;230;200mnoir\033[38;2;212;168;87m › \033[0m')"` Enter
Sleep 200ms
Type `printf '\033[38;2;30;30;30m⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀\n\033[38;2;35;30;20m⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣠⠤⠤⢄⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀\n\033[38;2;45;38;22m⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⡴⠋⠀⠀⠀⠀⠙⢦⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀\n\033[38;2;60;50;28m⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⡴⠋⠀⠀⠀⠀⠀⠀⠀⠀⠙⢦⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀\n\033[38;2;80;65;35m⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⡼⠁⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠈⢧⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀\n\033[38;2;100;82;44m⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢸⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢸⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀\n\033[38;2;120;98;52m⠀⠀⠀⠀⣀⠀⠀⠀⠀⠀⠀⠀⣸⣇⠀⠀⠀⢰⡆⠀⠀⠀⠀⠀⠀⠀⣸⣇⠀⠀⠀⠀⠀⢀⠀⠀⠀⠀⠀⠀\n\033[38;2;145;118;62m⠀⠀⠀⢠⣿⠀⠀⠀⠀⠀⠀⠀⣿⣿⣆⠀⠀⢸⡇⠀⢀⡀⠀⠀⢀⣼⣿⣿⠀⠀⠀⠀⠀⢸⣇⠀⠀⠀⠀⠀\n\033[38;2;165;134;70m⠀⠀⠀⣸⣿⠀⠀⢠⡄⠀⠀⠀⣿⣿⣿⣆⠀⢸⡇⢀⣿⡇⠀⣠⣿⣿⣿⣿⠀⠀⠀⣠⡄⢸⣿⠀⠀⠀⠀⠀\n\033[38;2;185;150;78m⠀⠀⠀⣿⣿⠀⠀⢸⡇⠀⠀⠀⣿⣿⣿⣿⣆⢸⡇⢸⣿⡇⣠⣿⣿⣿⣿⣿⠀⠀⠀⢸⡇⢸⣿⡇⠀⠀⠀⠀\n\033[38;2;200;162;84m⣀⣀⣴⣿⣿⣤⣤⣼⣧⣀⣀⣀⣿⣿⣿⣿⣿⣿⣧⣸⣿⣿⣿⣿⣿⣿⣿⣿⣀⣀⣤⣼⣧⣸⣿⣿⣤⣤⣀⠀\n\033[38;2;212;168;87m⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿\n\033[2;38;2;107;107;107m⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀◆ T H E  C I T Y  N E V E R  S L E E P S ◆⠀⠀⠀⠀⠀⠀⠀\n\n\033[38;2;58;58;58m███╗   ██╗ ██████╗ ██╗██████╗ \033[0m\n\033[38;2;90;80;50m████╗  ██║██╔═══██╗██║██╔══██╗\033[0m\n\033[38;2;140;115;65m██╔██╗ ██║██║   ██║██║██████╔╝\033[0m\n\033[38;2;180;148;80m██║╚██╗██║██║   ██║██║██╔══██╗\033[0m\n\033[38;2;212;168;87m██║ ╚████║╚██████╔╝██║██║  ██║\033[0m\n\033[38;2;212;168;87m╚═╝  ╚═══╝ ╚═════╝ ╚═╝╚═╝  ╚═╝\033[0m\n\033[38;2;107;107;107m          ◆ P R I V A T E  E Y E ◆\033[0m\n\n\033[2mAnother case. The terminal flickers to life.\033[0m\n'` Enter
Sleep 500ms
Show

Sleep 2500ms

Type "investigate --case=missing-data evidence/*.log"
Sleep 1200ms
Enter

Hide
Type `printf '\n\033[38;2;212;168;87m◆\033[0m Cross-referencing 47 evidence files...\n\033[38;2;122;158;126m✓\033[0m Pattern found: timestamps dont add up\n\033[38;2;212;168;87m◆\033[0m 3 suspects flagged in the access logs\n'` Enter
Sleep 200ms
Show
Sleep 3000ms
